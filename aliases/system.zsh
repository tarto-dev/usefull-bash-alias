# ==============================================================================
# System aliases — cross-platform (macOS + Linux)
# ==============================================================================

# ------------------------------------------------------------------------------
# Navigation
# ------------------------------------------------------------------------------
alias ..="cd ../"
alias ...="cd ../../"
alias ....="cd ../../../"
alias www='cd ~/Projects'

# ------------------------------------------------------------------------------
# Shell
# ------------------------------------------------------------------------------
alias reload='source ~/.zshrc'
alias r='reload'
alias c='clear'
alias vimbash='vim ~/.zshrc'
alias vimalias='vim ~/.bash_aliases'

# ------------------------------------------------------------------------------
# Modern CLI replacements (requires: bat, eza)
# ------------------------------------------------------------------------------
alias cat='bat --style=plain'
alias ls='eza --icons'
alias ll='eza -la --icons --git'
alias la='eza -a --icons'

# ------------------------------------------------------------------------------
# Networking
# ------------------------------------------------------------------------------
alias ping='ping -c 5'
alias fastping='ping -c 100 -s.2'
alias wget='wget -c'
alias header='curl -I'
alias headerc='curl -I --compress'

# ------------------------------------------------------------------------------
# Sudo helpers
# ------------------------------------------------------------------------------
alias root='sudo -i'
alias please='sudo'

# ------------------------------------------------------------------------------
# Fun
# ------------------------------------------------------------------------------
alias busy='cat /dev/urandom | hexdump -C | grep "ca fe"'
alias sl='sl'

# ------------------------------------------------------------------------------
# Vim
# ------------------------------------------------------------------------------
alias vim-update='vim +PluginInstall +qall'
