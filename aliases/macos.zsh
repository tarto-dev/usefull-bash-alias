# ==============================================================================
# macOS-only aliases — guarded, not sourced on Linux
# ==============================================================================

[[ "$(uname)" != "Darwin" ]] && return 0

# ------------------------------------------------------------------------------
# System info
# ------------------------------------------------------------------------------
alias cpuinfo='sysctl -n machdep.cpu.brand_string'
alias meminfo='vm_stat'

# ------------------------------------------------------------------------------
# Process
# ------------------------------------------------------------------------------
alias psmem='ps auxm | sort -nr -k 4'
alias psmem10='ps auxm | sort -nr -k 4 | head -10'
alias pscpu='ps auxr | sort -nr -k 3'
alias pscpu10='ps auxr | sort -nr -k 3 | head -10'
